# OpenAI for embeddings and LLM responses
OPENAI_API_KEY=sk-your-openai-key-here

# Vapi credentials - get these from https://vapi.ai/dashboard
VAPI_PRIVATE_KEY=your-vapi-private-key-here

# Vapi Assistant IDs (from Vapi Dashboard)
VAPI_CERTIFICATE_ASSISTANT_ID=your-certificate-assistant-id-here
VAPI_TAX_ASSISTANT_ID=your-tax-assistant-id-here
VAPI_GRIEVANCE_ASSISTANT_ID=your-grievance-assistant-id-here

# Your backend URL (use ngrok for local testing)
# Get from: python scripts/start_ngrok_and_update_vapi.py
BACKEND_URL=https://your-ngrok-url.ngrok-free.app
